# Westbury Social Manager — local configuration
# Copy this file to ".env" and fill in the values. NEVER commit your real .env.
# These are read only by the Electron main process and are never exposed to the UI.

# --- GitHub (to trigger workflows and read run status/logs) ---
# A fine-grained Personal Access Token for THIS repo with:
#   Actions: Read and write   |   Contents: Read
GITHUB_TOKEN=

# Your repo, in owner/name form.
GITHUB_REPO=willweathere/elite-frontend-starter

# The daily workflow file name (used for dispatch + status).
GITHUB_WORKFLOW_FILE=westbury-daily-post.yml

# Branch the workflow runs on.
GITHUB_BRANCH=main

# --- Buffer (to show connection status / channels) ---
# Same Buffer personal API key the automation uses (Settings > API in Buffer).
BUFFER_API_KEY=

# --- Local automation folder (the existing system this app controls) ---
# Path to the Westbury-Automation/automation folder. Defaults to the sibling
# folder in this repo if left blank.
AUTOMATION_DIR=
